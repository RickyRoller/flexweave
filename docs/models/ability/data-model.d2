# Ability system static model.

vars: {
  d2-config: {
    layout-engine: elk
    pad: 20
    theme-id: 200
  }
}

direction: right

classes: {
  artifact: {
    shape: class
  }
  collection: {
    shape: cylinder
  }
  boundary
  metadata: {
    shape: class
  }
}

authoring: Authoring model {
  definition: AbilityDefinition {
    key: String
    emits_lifecycle: bool
    emitted_channel_keys: "Vec<String>"
    payload_schema: PayloadSchema
  }
  definition.class: artifact

  definitions: AbilityDefinitions {
    shape: class
    definitions: "Vec<AbilityDefinition>"
    indexes: "BTreeMap<String, usize>"
  }
  definitions.class: artifact

  registry_errors: AbilityDefinitionRegistryError {
    DuplicateKey: "key String"
    MissingDefinition: "key String"
    InvalidDefinition: AbilityDefinitionError
  }
  registry_errors.class: metadata

  definition -> definitions: validate and insert
  definitions -> registry_errors: reject invalid bundle
}

runtime: Runtime store {
  grant_input: Grant {
    owner_id: ObjectId
    tags: Tags
    payload: Payload
  }
  grant_input.class: artifact

  granted: GrantedAbility {
    id: AbilityId
    definition_key: "Option<String>"
    owner_id: ObjectId
    tags: Tags
    payload: Payload
  }
  granted.class: artifact

  active: ActiveAbility {
    activation_id: AbilityActivationId
    ability_id: AbilityId
    definition_key: "Option<String>"
    owner_id: ObjectId
    tags: Tags
    payload: Payload
    committed: bool
  }
  active.class: artifact

  store: AbilityStore {
    shape: class
    next_id: AbilityId
    next_activation_id: AbilityActivationId
    abilities: "Vec<GrantedAbility>"
    ability_index_by_id: "HashMap<AbilityId, usize>"
    active_abilities: "Vec<ActiveAbility>"
    active_index_by_activation_id: "HashMap<AbilityActivationId, usize>"
  }
  store.class: artifact

  grant_input -> granted: grant copies runtime payload
  granted -> active: begin activation clones seed
  store -> granted: deterministic grant order
  store -> active: active execution order
}

caller: Caller boundary {
  objects: ObjectStore
  objects.class: boundary

  gate: AbilityActivationGate {
    shape: class
    can_activate(context, attempt): "Result<AbilityActivationDecision, Error>"
  }
  gate.class: artifact

  commit_action: AbilityCommitAction {
    shape: class
    apply_commit(context, active): "Result<(), Error>"
  }
  commit_action.class: artifact

  runtime: Runtime adapter
  runtime.class: boundary

  channel: EventChannel
  channel.class: boundary
}

events: AbilityLifecycleEvent {
  shape: class
  Attempted: AbilityActivationAttempt
  Rejected: AbilityActivationRejection
  Committed: ActiveAbility
  Started: ActiveAbility
  Canceled: ActiveAbility
  Revoked: ActiveAbility
  RolledBack: ActiveAbility
  Ended: ActiveAbility
}
events.class: artifact

authoring.definition -> runtime.grant_input: grant_with_definition validates metadata
authoring.definitions -> runtime.grant_input: grant_registered requires key
runtime.grant_input -> caller.objects: grant_checked validates live owner
runtime.store -> caller.gate: optional begin-time activation check
runtime.active -> caller.commit_action: optional commit-time action
caller.runtime -> runtime.store: composes begin, commit, end, cancel, rollback
events -> caller.channel: caller publishes owned facts
