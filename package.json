{
  "name": "flexweave",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run build:core",
    "build:core": "cargo build -p flexweave",
    "check": "ultracite check && bun run check:core",
    "check:core": "bun run check:core:fmt && bun run check:core:lint",
    "check:core:fmt": "cargo fmt -p flexweave -- --check",
    "check:core:lint": "cargo clippy -p flexweave --all-targets -- -D warnings",
    "docs:core": "cargo doc -p flexweave --no-deps",
    "fix": "ultracite fix",
    "test": "bun run test:core",
    "test:core": "cargo test -p flexweave",
    "verify": "bun run verify:core",
    "verify:core": "bun run check:core && bun run test:core && bun run build:core && bun run docs:core"
  },
  "devDependencies": {
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "typescript": "^6.0.3",
    "ultracite": "7.6.1"
  },
  "engines": {
    "bun": "1.3.13"
  },
  "packageManager": "bun@1.3.13"
}
